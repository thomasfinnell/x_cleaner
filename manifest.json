{
  "manifest_version": 3,
  "name": "X Cleaner",
  "short_name": "X Cleaner",
  "version": "0.98.2",
  "description": "Export and filter your X following & followers lists to CSV. All processing is local in your browser.",
  "author": "d2fl",
  "homepage_url": "https://d2fl.com/cleaner",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "cookies",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://api.x.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Cleaner",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["xc-fetch-sniffer.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*"],
      "js": ["xc-rest-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://x.com/*"],
      "js": ["list-preview.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "incognito": "not_allowed"
}